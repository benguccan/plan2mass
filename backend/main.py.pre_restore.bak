def _summary_for_floor(floor: dict[str, Any]) -> dict[str, int]:
    return {
        "polygon_points": len(floor["polygon"]),
        "inner_wall_count": len(floor["inner_walls"]),
        "door_count": len(floor["doors"]),
        "window_count": len(floor["windows"]),
        "room_count": len(floor["rooms"]),
    }


def _build_floor(
    floor_index: int,
    image_url: str,
    floor_height: float,
) -> dict[str, Any]:
    template = _floor_templates()[floor_index % len(_floor_templates())]
    floor = {
        "floor_index": floor_index + 1,
        "image_url": image_url,
        "polygon": _base_polygon(),
        "inner_walls": template["inner_walls"],
        "doors": template["doors"],
        "windows": template["windows"],
        "rooms": template["rooms"],
        "debug": {},
        "height": floor_height,
    }
    floor["summary"] = _summary_for_floor(floor)
    return floor


def _build_project_payload(project_id: str, floors: list[dict[str, Any]], floor_height: float) -> dict[str, Any]:
    total_rooms = sum(len(f["rooms"]) for f in floors)
    total_doors = sum(len(f["doors"]) for f in floors)
    total_windows = sum(len(f["windows"]) for f in floors)
    total_inner = sum(len(f["inner_walls"]) for f in floors)
    floor_count = len(floors)

    return {
        "project_id": project_id,
        "floor_count": floor_count,
        "floor_height": floor_height,
        "building_height": round(floor_count * floor_height, 1),
        "summary": {
            "room_count": total_rooms,
            "door_count": total_doors,
            "window_count": total_windows,
            "inner_wall_count": total_inner,
        },
        "floors": floors,
    }


def _project_json_path(project_id: str) -> Path:
    return PROJECTS_DIR / project_id / "project.json"


def _save_project(payload: dict[str, Any]) -> None:
    project_dir = PROJECTS_DIR / payload["project_id"]
    project_dir.mkdir(parents=True, exist_ok=True)
    _project_json_path(payload["project_id"]).write_text(
        json.dumps(payload, ensure_ascii=False, indent=2),
        encoding="utf-8",
    )


def _load_project(project_id: str) -> dict[str, Any]:
    path = _project_json_path(project_id)
    if not path.exists():
        raise HTTPException(status_code=404, detail="Project not found")
    return json.loads(path.read_text(encoding="utf-8"))


@app.get("/health")
def health() -> dict[str, str]:
    return {"status": "ok"}


@app.post("/projects/upload")
async def upload_project(
    files: list[UploadFile] = File(...),
    floor_count: int = Form(3),
) -> dict[str, Any]:
    if floor_count < 1 or floor_count > 3:
        raise HTTPException(status_code=400, detail="floor_count must be between 1 and 3")
    if not files:
        raise HTTPException(status_code=400, detail="No files uploaded")

    project_id = f"proj-{uuid.uuid4().hex[:10]}"
    project_dir = PROJECTS_DIR / project_id
    floor_height = 3.2
    project_dir.mkdir(parents=True, exist_ok=True)

    pdf_files = [f for f in files if f.filename and f.filename.lower().endswith(".pdf")]
    image_files = [f for f in files if not (f.filename and f.filename.lower().endswith(".pdf"))]

    floors: list[dict[str, Any]] = []

    if pdf_files:
        # Keep workflow stable even when PDF page extraction is unavailable in local env.
        for idx in range(floor_count):
            floors.append(_build_floor(idx, f"/demo/floor_{idx + 1}.png", floor_height))
    else:
        if len(image_files) != floor_count:
            raise HTTPException(
                status_code=400,
                detail=f"Expected {floor_count} image file(s), received {len(image_files)}",
            )

        for idx, file in enumerate(image_files):
            original_name = file.filename or f"floor_{idx + 1}.png"
            ext = Path(original_name).suffix.lower()
            if ext not in {".png", ".jpg", ".jpeg"}:
                raise HTTPException(status_code=400, detail="Only PDF/PNG/JPG/JPEG allowed")

            safe_name = f"floor_{idx + 1}{ext}"
            saved_path = project_dir / safe_name
            with saved_path.open("wb") as out:
                shutil.copyfileobj(file.file, out)

            floors.append(_build_floor(idx, f"/uploads/projects/{project_id}/{safe_name}", floor_height))

    payload = _build_project_payload(project_id, floors, floor_height)
    _save_project(payload)

    return {"ok": True, "project_id": project_id, "floor_count": floor_count}


@app.get("/projects/{project_id}")
def get_project(project_id: str, floor_height: float = 3.2) -> dict[str, Any]:
    payload = _load_project(project_id)
    payload["floor_height"] = floor_height
    payload["building_height"] = round(payload["floor_count"] * floor_height, 1)
    for floor in payload.get("floors", []):
        floor["height"] = floor_height
    return payload

